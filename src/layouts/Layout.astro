---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'University Diversity Index — 大学のダイバーシティ推進状況を可視化・比較するプラットフォーム' } = Astro.props;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | UDI — University Diversity Index</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Noto+Sans+JP:wght@300;400;500;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --accent: #e8ff5a;
      --ink: #0f0f0f;
      --surface: #f5f5f4;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--ink); color: #e8e8e6; font-family: 'Noto Sans JP', 'DM Sans', sans-serif; }
    ::selection { background: var(--accent); color: var(--ink); }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #1a1a18; }
    ::-webkit-scrollbar-thumb { background: #3d3d39; border-radius: 3px; }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="border-b border-white/10 sticky top-0 z-50 backdrop-blur-md" style="background: rgba(15,15,15,0.92);">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-8 h-8 rounded-sm flex items-center justify-center font-display font-bold text-sm" style="background: var(--accent); color: var(--ink);">
          UDI
        </div>
        <div>
          <span class="font-display font-bold text-white text-lg tracking-tight">University Diversity Index</span>
          <span class="hidden sm:inline text-white/30 text-xs ml-2 font-mono">beta</span>
        </div>
      </a>
      <nav class="flex items-center gap-6">
        <a href="/" class="text-sm text-white/60 hover:text-white transition-colors">比較表</a>
        <a href="/#about" class="text-sm text-white/60 hover:text-white transition-colors">このサイトについて</a>
        <a
          href="https://github.com/Hana-saw/University_Diversity_Index"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm px-3 py-1.5 rounded-md border border-white/20 text-white/70 hover:border-white/50 hover:text-white transition-all"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/10 mt-24 py-12">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        <div>
          <div class="font-display font-bold text-white mb-2">University Diversity Index</div>
          <p class="text-sm text-white/40 leading-relaxed">
            大学のダイバーシティ推進状況をオープンに可視化し、
            改善を促進するコミュニティドリブンなプラットフォームです。
          </p>
        </div>
        <div>
          <div class="text-xs font-mono text-white/30 uppercase tracking-widest mb-3">コントリビュート</div>
          <ul class="space-y-2 text-sm text-white/50">
            <li><a href="https://github.com/Hana-saw/University_Diversity_Index/blob/main/CONTRIBUTING.md" class="hover:text-white transition-colors">貢献ガイドライン</a></li>
            <li><a href="https://github.com/Hana-saw/University_Diversity_Index/issues/new" class="hover:text-white transition-colors">データの誤りを報告</a></li>
            <li><a href="https://github.com/Hana-saw/University_Diversity_Index/pulls" class="hover:text-white transition-colors">オープンなPR一覧</a></li>
          </ul>
        </div>
        <div>
          <div class="text-xs font-mono text-white/30 uppercase tracking-widest mb-3">免責事項</div>
          <p class="text-xs text-white/30 leading-relaxed">
            掲載データは各大学の公開情報をもとにコミュニティが収集・整理したものです。
            正確性を期していますが、公式情報は各大学の公式サイトをご確認ください。
          </p>
        </div>
      </div>
      <div class="border-t border-white/10 pt-6 flex items-center justify-between">
        <span class="text-xs text-white/20 font-mono">© 2024 UDI Contributors — CC BY 4.0</span>
        <span class="text-xs text-white/20">データはGitHubで管理・公開されています</span>
      </div>
    </div>
  </footer>
</body>
</html>
