---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const universities = await getCollection('universities');
  return universities.map(u => ({
    params: { slug: u.slug },
    props: { university: u },
  }));
}

const { university } = Astro.props;
const { data, slug } = university;
const { Content } = await university.render();

// GitHub edit URL
const GITHUB_OWNER = 'your-org';
const GITHUB_REPO = 'university-diversity-index';
const GITHUB_BRANCH = 'main';
const editUrl = `https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/edit/${GITHUB_BRANCH}/src/content/universities/${slug}.md`;
const newIssueUrl = `https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/issues/new?title=データ修正: ${encodeURIComponent(data.name)}&body=${encodeURIComponent(`## 修正対象\n\n大学名: ${data.name}\nファイル: \`src/content/universities/${slug}.md\`\n\n## 修正内容\n\n<!-- 修正したい内容を具体的に記載してください -->\n\n## 情報源\n\n<!-- 参照した公式サイトや資料のURLを記載してください -->`)}`;

const LGBTQ_STYLE = {
  '実施済み': { bg: 'rgba(22,163,74,0.12)', border: 'rgba(22,163,74,0.3)', text: '#4ade80', dot: '#16a34a' },
  '検討中':   { bg: 'rgba(202,138,4,0.12)',  border: 'rgba(202,138,4,0.3)',  text: '#facc15', dot: '#ca8a04' },
  '未着手':   { bg: 'rgba(220,38,38,0.12)',  border: 'rgba(220,38,38,0.3)',  text: '#f87171', dot: '#dc2626' },
};
const lgbtqStyle = LGBTQ_STYLE[data.lgbtq_policy];
---

<Layout title={data.name} description={`${data.name}のダイバーシティ推進状況（女性教授比率・LGBTQ+施策・バリアフリー）を確認・比較できます。`}>

  <!-- Breadcrumb -->
  <div class="max-w-5xl mx-auto px-6 pt-8">
    <nav style="font-size: 13px; color: rgba(255,255,255,0.3); font-family: 'JetBrains Mono', monospace;">
      <a href="/" style="color: rgba(255,255,255,0.4); text-decoration: none; hover:color: white;">UDI</a>
      <span style="margin: 0 8px; opacity: 0.4;">/</span>
      <span style="color: rgba(255,255,255,0.6);">{data.name}</span>
    </nav>
  </div>

  <!-- Header -->
  <section class="max-w-5xl mx-auto px-6 pt-8 pb-12">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
      <div>
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
          <span style="font-size: 12px; color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.07); padding: 3px 10px; border-radius: 4px;">{data.prefecture}</span>
          <span style="font-size: 12px; color: rgba(255,255,255,0.3);">{data.region}</span>
        </div>
        <h1 class="font-display font-bold text-white" style="font-size: clamp(28px, 4vw, 48px); letter-spacing: -0.03em; line-height: 1.1;">
          {data.name}
        </h1>
        {data.name_en && (
          <p style="font-size: 16px; color: rgba(255,255,255,0.3); margin-top: 4px; font-family: 'DM Sans', sans-serif;">{data.name_en}</p>
        )}
        <a
          href={data.official_url}
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-flex; align-items: center; gap: 5px; margin-top: 10px; font-size: 13px; color: rgba(255,255,255,0.35); text-decoration: none; font-family: 'JetBrains Mono', monospace;"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
          {data.official_url.replace('https://', '')}
        </a>
      </div>

      <!-- Edit button -->
      <div style="flex-shrink: 0; display: flex; flex-direction: column; gap: 10px; min-width: 220px;">
        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          style="display: flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 20px; background: #e8ff5a; color: #0f0f0f; border-radius: 10px; font-weight: 700; font-size: 14px; text-decoration: none; transition: all 0.2s; font-family: 'Noto Sans JP', sans-serif;"
          onmouseover="this.style.background='#f5ffb0'"
          onmouseout="this.style.background='#e8ff5a'"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
          GitHubで編集・提案する
        </a>
        <a
          href={newIssueUrl}
          target="_blank"
          rel="noopener noreferrer"
          style="display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 20px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.6); border-radius: 10px; font-size: 13px; text-decoration: none; transition: all 0.2s;"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          修正を提案（Issue）
        </a>
        <p style="font-size: 11px; color: rgba(255,255,255,0.2); text-align: center; line-height: 1.5; font-family: 'JetBrains Mono', monospace;">
          GitHubアカウントが必要です<br/>Pull Requestでデータを改善できます
        </p>
      </div>
    </div>
  </section>

  <!-- Data cards -->
  <section class="max-w-5xl mx-auto px-6 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">

      <!-- Female prof ratio -->
      <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 24px;">
        <div style="font-size: 11px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3); margin-bottom: 12px;">女性教授比率</div>
        <div style="font-family: 'Syne', sans-serif; font-size: 52px; font-weight: 800; color: #e8ff5a; letter-spacing: -0.04em; line-height: 1;">
          {data.gender_ratio_female_prof}
          <span style="font-size: 22px; color: rgba(232,255,90,0.6);">%</span>
        </div>
        <div style="margin-top: 12px; height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden;">
          <div style={`width: ${data.gender_ratio_female_prof}%; height: 100%; background: #e8ff5a; border-radius: 3px;`} />
        </div>
        <div style="font-size: 11px; color: rgba(255,255,255,0.25); margin-top: 6px; font-family: 'JetBrains Mono', monospace;">国立大学平均: 約17%</div>
      </div>

      <!-- LGBTQ -->
      <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 24px;">
        <div style="font-size: 11px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3); margin-bottom: 12px;">LGBTQ+施策</div>
        <div style={`display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border-radius: 99px; background: ${lgbtqStyle.bg}; border: 1px solid ${lgbtqStyle.border}; color: ${lgbtqStyle.text}; font-weight: 600; font-size: 18px; margin-bottom: 12px;`}>
          <span style={`width: 8px; height: 8px; border-radius: 50%; background: ${lgbtqStyle.dot}; flex-shrink: 0;`}></span>
          {data.lgbtq_policy}
        </div>
        {data.lgbtq_policy_detail && (
          <p style="font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.6; margin-top: 8px;">
            {data.lgbtq_policy_detail.split('\n')[0]}
          </p>
        )}
      </div>

      <!-- Barrier-free -->
      <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 24px;">
        <div style="font-size: 11px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3); margin-bottom: 12px;">バリアフリースコア</div>
        <div style="font-family: 'Syne', sans-serif; font-size: 52px; font-weight: 800; color: #e8e8e6; letter-spacing: -0.04em; line-height: 1;">
          {data.barrier_free_score}
          <span style="font-size: 22px; color: rgba(255,255,255,0.3);">/5</span>
        </div>
        <div style="display: flex; gap: 5px; margin-top: 12px;">
          {[1,2,3,4,5].map(i => (
            <div style={`height: 6px; flex: 1; border-radius: 3px; background: ${i <= data.barrier_free_score ? '#e8ff5a' : 'rgba(255,255,255,0.1)'};`} />
          ))}
        </div>
        {data.barrier_free_detail && (
          <p style="font-size: 11px; color: rgba(255,255,255,0.25); line-height: 1.5; margin-top: 8px;">
            {data.barrier_free_detail.split('\n')[0].slice(0, 60)}...
          </p>
        )}
      </div>
    </div>

    {data.international_ratio && (
      <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 16px 24px; display: flex; align-items: center; gap: 16px; margin-bottom: 8px;">
        <div style="font-size: 11px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.25); min-width: 140px;">外国人教員比率</div>
        <div style="flex: 1; height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden;">
          <div style={`width: ${data.international_ratio}%; height: 100%; background: rgba(37,99,235,0.8); border-radius: 2px;`} />
        </div>
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 14px; color: rgba(255,255,255,0.6); min-width: 50px; text-align: right;">{data.international_ratio}%</span>
      </div>
    )}
  </section>

  <!-- Detail text from markdown -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Main content -->
      <div class="md:col-span-2">
        <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 32px;">
          <div class="prose-udi">
            <Content />
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-4">

        <!-- Update history placeholder -->
        <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 20px;">
          <div style="font-size: 11px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.25); margin-bottom: 14px;">更新履歴</div>
          <div style="space-y: 8px;">
            <div style="display: flex; gap: 10px; align-items: flex-start; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.06);">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: #e8ff5a; flex-shrink: 0; margin-top: 5px;"></span>
              <div>
                <div style="font-size: 12px; color: rgba(255,255,255,0.7); font-weight: 500;">最終更新</div>
                <div style="font-size: 11px; color: rgba(255,255,255,0.3); font-family: 'JetBrains Mono', monospace; margin-top: 2px;">{data.last_updated}</div>
              </div>
            </div>
            <div style="padding-top: 10px;">
              <a
                href={`https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/commits/main/src/content/universities/${slug}.md`}
                target="_blank"
                rel="noopener noreferrer"
                style="font-size: 12px; color: rgba(255,255,255,0.35); text-decoration: none; display: flex; align-items: center; gap: 5px;"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="3"/><path d="M20.188 10.934c.33 1.298.33 2.634 0 3.932-1.244 4.905-6.001 7.898-10.906 6.654C4.377 20.276 1.384 15.519 2.628 10.614 3.872 5.709 8.629 2.716 13.534 3.96a9.003 9.003 0 016.654 6.974z"/>
                </svg>
                GitHub で全履歴を見る
              </a>
            </div>
          </div>
        </div>

        <!-- Data source -->
        {data.data_source && (
          <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 20px;">
            <div style="font-size: 11px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.25); margin-bottom: 10px;">データ出典</div>
            <p style="font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.6;">{data.data_source}</p>
          </div>
        )}

        <!-- Contribute CTA -->
        <div style="background: rgba(232,255,90,0.05); border: 1px solid rgba(232,255,90,0.15); border-radius: 14px; padding: 20px;">
          <div style="font-size: 13px; color: rgba(232,255,90,0.8); font-weight: 600; margin-bottom: 8px;">このデータを改善する</div>
          <p style="font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.6; margin-bottom: 14px;">
            古い情報や誤りを見つけた場合、GitHubのPull Requestで改善を提案できます。
          </p>
          <a
            href={editUrl}
            target="_blank"
            rel="noopener noreferrer"
            style="display: block; text-align: center; padding: 10px; background: #e8ff5a; color: #0f0f0f; border-radius: 8px; font-size: 13px; font-weight: 700; text-decoration: none;"
          >
            GitHubで編集する →
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .prose-udi :global(h2) {
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    margin-top: 28px;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    letter-spacing: -0.01em;
  }
  .prose-udi :global(h2:first-child) { margin-top: 0; }
  .prose-udi :global(p) {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.8;
    margin-bottom: 14px;
  }
  .prose-udi :global(strong) { color: rgba(255,255,255,0.75); font-weight: 600; }
  .prose-udi :global(ul), .prose-udi :global(ol) { padding-left: 20px; margin-bottom: 14px; }
  .prose-udi :global(li) { font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.7; margin-bottom: 4px; }
</style>
